
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Règle par défaut : Personne ne peut lire ou écrire, sauf si spécifié ci-dessous.
    match /{document=**} {
      allow read, write: if false;
    }

    // Les collections publiques sont lisibles par tout le monde.
    // L'écriture est réservée aux administrateurs (utilisateurs authentifiés).
    match /news/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /promotions/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // La collection des avis est lisible par tout le monde.
    // Tout le monde peut en créer un (create).
    // Seuls les admins peuvent modifier ou supprimer.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Tout le monde peut créer un message de support.
    // Seuls les admins peuvent les lire, les mettre à jour (ex: marquer comme lu) ou les supprimer.
    match /supportMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}

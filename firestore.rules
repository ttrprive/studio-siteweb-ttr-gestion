
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin role based on a specific email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "emapms@gmail.com";
    }

    // Reviews can be read by anyone and created by anyone.
    // Admin can delete them.
    match /reviews/{reviewId} {
      allow read, create: if true;
      allow delete: if isAdmin();
    }

    // News can be read by anyone.
    // Only admins can create, update, or delete news.
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promotions can be read by anyone.
    // Only admins can create, update, or delete promotions.
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Support messages can be created by anyone.
    // Only admins can read or modify them (e.g., mark as read).
    match /supportMessages/{messageId} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if false; // Generally not a good idea to delete support messages
    }
  }
}


rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Par défaut, refuser l'accès à toutes les collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Autoriser la lecture publique pour la collection 'news'
    match /news/{newsId} {
      allow get, list: if true;
      allow create, update, delete: if request.auth != null; // Seuls les utilisateurs authentifiés peuvent écrire
    }

    // Ajoutez ici des règles pour vos autres collections (reviews, supportMessages, etc.)
    // Exemple : autoriser uniquement les admins à écrire.
    // Pour l'instant, elles restent protégées par la règle par défaut.
    match /reviews/{reviewId} {
        allow get, list: if true;
        allow create: if true; // Permettre à n'importe qui d'ajouter un avis
        allow update, delete: if request.auth != null;
    }

    match /promotions/{promoId} {
        allow get, list: if true;
        allow create, update, delete: if request.auth != null;
    }

    match /supportMessages/{messageId} {
        allow create: if true;
        allow read, update, delete: if request.auth != null;
    }
    
    match /settings/{settingId} {
        allow get, list: if true;
        allow write: if request.auth != null;
    }
  }
}

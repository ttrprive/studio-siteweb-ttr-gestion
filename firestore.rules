
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin role
    function isAdmin() {
      // Un utilisateur est admin si son document dans la collection 'users'
      // a le champ 'role' égal à 'admin'.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Les utilisateurs ne peuvent lire et écrire que leurs propres informations.
    // Les admins peuvent lire les informations de n'importe quel utilisateur.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId;
    }

    // Tout le monde peut lire les actualités.
    // Seuls les admins peuvent créer, modifier ou supprimer des actualités.
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tout le monde peut lire les promotions.
    // Seuls les admins peuvent les gérer.
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Les avis ne sont lisibles publiquement que s'ils sont approuvés.
    match /reviews/{reviewId} {
      // Tout le monde peut lire les avis approuvés.
      allow get: if resource.data.approved == true;
      // Pour lister les avis, on s'assure de ne récupérer que ceux approuvés.
      allow list: if query.filters.length > 0 && query.filters[0][0] == 'approved' && query.filters[0][2] == true;

      // Un utilisateur authentifié peut créer un avis, mais il ne peut pas l'approuver lui-même.
      allow create: if request.auth != null && request.resource.data.approved == false;

      // Seuls les admins peuvent lire tous les avis (approuvés ou non) et les approuver.
      allow read, update: if isAdmin();
    }

    // Les messages de support ne peuvent être lus que par les admins.
    // N'importe qui (même non authentifié) peut envoyer un message.
    match /supportMessages/{messageId} {
      allow read, update: if isAdmin();
      allow create: if true;
    }
  }
}
